{
  "name": "beanz",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "bun run build && wrangler dev --config dist/server/wrangler.json",
    "astro": "astro",
    "lint": "oxlint",
    "format": "oxfmt",
    "prepare": "husky",
    "generate-types": "wrangler types",
    "deploy": "bun run build && wrangler deploy --config dist/server/wrangler.json",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.10",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.8",
    "tailwindcss": "^4.2.4",
    "wrangler": "^4.84.1"
  },
  "devDependencies": {
    "oxlint": "^1.61.0",
    "oxfmt": "^0.46.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  }
